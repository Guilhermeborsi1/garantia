<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="garantia_list_view" model="ir.ui.view">
        <field name="name">garantia.garantia.list</field>
        <field name="model">garantia.garantia</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="garantia_form_view" model="ir.ui.view">
        <field name="name">garantia.garantia.form</field>
        <field name="model">garantia.garantia</field>
        <field name="arch" type="xml">
            <form string="Garantia">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_id"/>
                        <field name="description"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_garantia" model="ir.actions.act_window">
        <field name="name">Garantias</field>
        <field name="res_model">garantia.garantia</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_garantia_root" name="Garantias" sequence="10"/>
    <menuitem id="menu_garantia_items"
              name="Gerenciar Garantias"
              parent="menu_garantia_root"
              action="action_garantia"
              sequence="10"/>

</odoo>